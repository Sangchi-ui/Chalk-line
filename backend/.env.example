# --- Model provider (pick one; code defaults to LLM_PROVIDER) ---
LLM_PROVIDER=gemini            # gemini | groq | mistral

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# --- Skill files (your hand-built, empirically-tested skills) ---
# Point these at the SKILL.md files you built and verified in sandbox testing.
MANIM_SKILL_PATH=./skills/manim/SKILL.md
THREEJS_SKILL_PATH=./skills/threejs/SKILL.md

# --- Rendering ---
MANIM_QUALITY=l                # l=480p15 (fast/draft), m=720p30, h=1080p60
RENDER_DIR=./renders
MANIM_TIMEOUT_SECONDS=90

# --- Server ---
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,null
